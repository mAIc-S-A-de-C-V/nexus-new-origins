{
  "name": "@nexus/app-sdk",
  "version": "1.0.0",
  "description": "SDK for building third-party apps on the Nexus platform",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "files": [
    "dist",
    "template",
    "cli"
  ],
  "bin": {
    "nexus-app": "./cli/index.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "echo no tests yet"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "dependencies": {
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "typescript": "^5.4"
  },
  "keywords": ["nexus", "app", "sdk", "iframe", "sandbox", "rpc"],
  "license": "UNLICENSED"
}
