# Copy to .env.production on the host (or just `export` these into the shell
# before `docker compose up -d`) to wire HTTPS through the Caddy reverse proxy.
#
# Replace `app.maic.ai` with whichever hostname you set up.

# ── Caddy ───────────────────────────────────────────────────────────────────
# The hostname Caddy serves and requests Let's Encrypt certs for.
DOMAIN=app.maic.ai

# ── Frontend build args (Vite bakes these into the JS bundle at build time) ─
# Each backend service is reverse-proxied at /api/<slug>/ behind Caddy.
VITE_CONNECTOR_SERVICE_URL=https://app.maic.ai/api/connector
VITE_PIPELINE_SERVICE_URL=https://app.maic.ai/api/pipeline
VITE_INFERENCE_SERVICE_URL=https://app.maic.ai/api/inference
VITE_ONTOLOGY_SERVICE_URL=https://app.maic.ai/api/ontology
VITE_EVENT_LOG_SERVICE_URL=https://app.maic.ai/api/event-log
VITE_AUDIT_SERVICE_URL=https://app.maic.ai/api/audit
VITE_CORRELATION_ENGINE_URL=https://app.maic.ai/api/correlation
VITE_PROCESS_ENGINE_URL=https://app.maic.ai/api/process
VITE_ALERT_ENGINE_URL=https://app.maic.ai/api/alert
VITE_AUTH_SERVICE_URL=https://app.maic.ai/api/auth
VITE_PROJECT_MGMT_URL=https://app.maic.ai/api/project
VITE_FINANCE_SERVICE_URL=https://app.maic.ai/api/finance
VITE_LOGIC_SERVICE_URL=https://app.maic.ai/api/logic
VITE_AGENT_SERVICE_URL=https://app.maic.ai/api/agent
VITE_UTILITY_SERVICE_URL=https://app.maic.ai/api/utility
VITE_ANALYTICS_SERVICE_URL=https://app.maic.ai/api/analytics
VITE_EVAL_SERVICE_URL=https://app.maic.ai/api/eval
VITE_LINEAGE_SERVICE_URL=https://app.maic.ai/api/lineage
VITE_SEARCH_SERVICE_URL=https://app.maic.ai/api/search
VITE_DATA_QUALITY_SERVICE_URL=https://app.maic.ai/api/data-quality
VITE_COLLABORATION_SERVICE_URL=https://app.maic.ai/api/collaboration
VITE_API_GATEWAY_URL=https://app.maic.ai/api/gateway
VITE_ADMIN_SERVICE_URL=https://app.maic.ai/api/admin
VITE_KERNEL_SERVICE_URL=https://app.maic.ai/api/kernel

# ── Backend CORS allowlist ──────────────────────────────────────────────────
# Each backend's ALLOWED_ORIGINS env already includes ${ALLOWED_ORIGIN_EC2}
# alongside localhost; setting it here adds the HTTPS hostname.
ALLOWED_ORIGIN_EC2=https://app.maic.ai
