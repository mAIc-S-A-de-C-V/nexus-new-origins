FROM node:20.18.0-alpine AS builder

WORKDIR /app
COPY package*.json ./
RUN npm install

COPY . .

ARG VITE_CONNECTOR_SERVICE_URL
ARG VITE_PIPELINE_SERVICE_URL
ARG VITE_INFERENCE_SERVICE_URL
ARG VITE_ONTOLOGY_SERVICE_URL
ARG VITE_EVENT_LOG_SERVICE_URL
ARG VITE_AUDIT_SERVICE_URL
ARG VITE_CORRELATION_ENGINE_URL
ARG VITE_PROCESS_ENGINE_URL
ARG VITE_ALERT_ENGINE_URL
ARG VITE_AUTH_SERVICE_URL
ARG VITE_PROJECT_MGMT_URL
ARG VITE_FINANCE_SERVICE_URL
ARG VITE_LOGIC_SERVICE_URL
ARG VITE_AGENT_SERVICE_URL
ARG VITE_UTILITY_SERVICE_URL
ARG VITE_ANALYTICS_SERVICE_URL
ARG VITE_EVAL_SERVICE_URL
ARG VITE_LINEAGE_SERVICE_URL
ARG VITE_SEARCH_SERVICE_URL
ARG VITE_DATA_QUALITY_SERVICE_URL
ARG VITE_COLLABORATION_SERVICE_URL
ARG VITE_API_GATEWAY_URL
ARG VITE_ADMIN_SERVICE_URL
ARG VITE_KERNEL_SERVICE_URL

ENV VITE_CONNECTOR_SERVICE_URL=$VITE_CONNECTOR_SERVICE_URL
ENV VITE_PIPELINE_SERVICE_URL=$VITE_PIPELINE_SERVICE_URL
ENV VITE_INFERENCE_SERVICE_URL=$VITE_INFERENCE_SERVICE_URL
ENV VITE_ONTOLOGY_SERVICE_URL=$VITE_ONTOLOGY_SERVICE_URL
ENV VITE_EVENT_LOG_SERVICE_URL=$VITE_EVENT_LOG_SERVICE_URL
ENV VITE_AUDIT_SERVICE_URL=$VITE_AUDIT_SERVICE_URL
ENV VITE_CORRELATION_ENGINE_URL=$VITE_CORRELATION_ENGINE_URL
ENV VITE_PROCESS_ENGINE_URL=$VITE_PROCESS_ENGINE_URL
ENV VITE_ALERT_ENGINE_URL=$VITE_ALERT_ENGINE_URL
ENV VITE_AUTH_SERVICE_URL=$VITE_AUTH_SERVICE_URL
ENV VITE_PROJECT_MGMT_URL=$VITE_PROJECT_MGMT_URL
ENV VITE_FINANCE_SERVICE_URL=$VITE_FINANCE_SERVICE_URL
ENV VITE_LOGIC_SERVICE_URL=$VITE_LOGIC_SERVICE_URL
ENV VITE_AGENT_SERVICE_URL=$VITE_AGENT_SERVICE_URL
ENV VITE_UTILITY_SERVICE_URL=$VITE_UTILITY_SERVICE_URL
ENV VITE_ANALYTICS_SERVICE_URL=$VITE_ANALYTICS_SERVICE_URL
ENV VITE_EVAL_SERVICE_URL=$VITE_EVAL_SERVICE_URL
ENV VITE_LINEAGE_SERVICE_URL=$VITE_LINEAGE_SERVICE_URL
ENV VITE_SEARCH_SERVICE_URL=$VITE_SEARCH_SERVICE_URL
ENV VITE_DATA_QUALITY_SERVICE_URL=$VITE_DATA_QUALITY_SERVICE_URL
ENV VITE_COLLABORATION_SERVICE_URL=$VITE_COLLABORATION_SERVICE_URL
ENV VITE_API_GATEWAY_URL=$VITE_API_GATEWAY_URL
ENV VITE_ADMIN_SERVICE_URL=$VITE_ADMIN_SERVICE_URL
ENV VITE_KERNEL_SERVICE_URL=$VITE_KERNEL_SERVICE_URL

RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
