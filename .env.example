# Copy this file to .env and fill in real values
# NEVER commit .env to git

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Email / SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com

# Database (production — override defaults)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=localhost

# Auth
JWT_ISSUER=https://your-domain.com/auth
APP_BASE_URL=https://your-domain.com

# JWT signing key (RSA private key PEM, generate with: python3 -c "from jwt_utils import generate_key_pem; print(generate_key_pem())")
# If not set, a new key is generated on each restart (all sessions lost on restart)
JWT_PRIVATE_KEY_PEM=

# Seed password for default admin@maic.ai account (set to disable random seed)
ADMIN_SEED_PASSWORD=

# OIDC (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_BASE_URL=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common

# Production domain for nginx
DOMAIN=your-domain.com

# CORS (comma-separated list of allowed frontend origins)
ALLOWED_ORIGINS=https://your-domain.com

# Encryption key for connector credentials (32-byte hex, generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
CREDENTIAL_ENCRYPTION_KEY=generate-a-32-byte-hex-key-here

# Backup encryption key (generate: openssl rand -hex 32)
BACKUP_ENCRYPTION_KEY=generate-a-random-hex-key-here
